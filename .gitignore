# Secrets — never commit these
.env
.env.local
.env.*.local

# Node dependencies (reinstalled from package.json — no need to track)
node_modules/

# Playwright browser session / storage state
# This is the logged-in LinkedIn session. Treat it like a credential.
.auth/
playwright/.auth/
storageState.json
storage-state.json
user-data-dir/
.playwright-session/
playwright-user-data/

# Local database (prospect data, drafts, threads — stays on this machine)
*.db
*.db-journal
*.sqlite
*.sqlite3
*.sqlite3-journal

# Logs
*.log
logs/

# Python
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Local data (DB, BNI PDF, anything operator drops in)
data/

# Playwright MCP runtime artifacts (already created during session)
.playwright-mcp/

# OS / editor cruft
.DS_Store
Thumbs.db
.vscode/
.idea/
