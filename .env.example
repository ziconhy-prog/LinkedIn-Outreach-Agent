# LinkedIn Outreach Agent — environment variables
#
# Copy this file to .env and fill in the values you need.
# Each phase activates more variables; you don't need to fill anything in
# until the corresponding phase asks for it. .env is in .gitignore — never
# commit it.

# ===================================================================
# Phase 1 (foundation) — no secrets needed.
# ===================================================================

# ===================================================================
# Phase 2+ (LinkedIn via Playwright)
# ===================================================================

# Where to store the logged-in LinkedIn browser profile.
# Default: .playwright-session/ in the project root. Leave blank to use default.
PLAYWRIGHT_USER_DATA_DIR=

# ===================================================================
# Phase 4 (Telegram bot)
# ===================================================================

# Get the token by talking to @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=

# Your Telegram numeric user ID. Use @userinfobot to find it.
# The bot will refuse to talk to anyone whose ID isn't this one.
TELEGRAM_OPERATOR_USER_ID=

# ===================================================================
# Phase 8 (Google Calendar)
# ===================================================================

# Path to your Google OAuth credentials JSON file
# (downloaded from Google Cloud Console after creating an OAuth client).
GOOGLE_OAUTH_CREDENTIALS_PATH=

# Where the OAuth refresh token is stored after the one-time
# /connect-calendar setup. Default: data/google_oauth_token.json
GOOGLE_OAUTH_TOKEN_PATH=

# ===================================================================
# Optional Phase 1 path overrides (advanced — usually leave blank)
# ===================================================================

# Override the default DB location (default: data/outreach.db)
DB_PATH=

# Override the voice samples folder (default: files/voice-samples/)
VOICE_SAMPLES_DIR=

# Override the data directory (default: data/)
DATA_DIR=

# Override the logs directory (default: logs/)
LOGS_DIR=
